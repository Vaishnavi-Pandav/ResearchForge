# ──────────────────────────────────────────────────────────────────────────────
# ResearchForge — Root Environment Variables
# Copy this to .env and fill in your values.
# Only GOOGLE_API_KEY is required to run the AI agents (completely free).
# ──────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=ResearchForge
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=change-me-to-a-random-32-char-string
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=researchforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── FREE LLM: Google Gemini 1.5 Flash ─────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1 million tokens/day — more than enough for research
GOOGLE_API_KEY=your-google-ai-studio-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── FREE Web Search: DuckDuckGo ───────────────────────────────────────────────
# No API key needed! DuckDuckGo search is 100% free.
# The duckduckgo-search Python library handles everything.

# ── FREE Embeddings: Sentence Transformers (local) ────────────────────────────
# No API key needed! Runs locally using sentence-transformers.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=researchforge_memory

# ── Firebase Admin SDK (for backend JWT verification) ─────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Place the JSON file in the backend directory and set the path below
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
